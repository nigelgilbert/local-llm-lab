#!/usr/bin/env bash
# install-claw-16gb — one-shot installer for the claw-code 16 GB stack.
#
# Stack:
#   - OrbStack (Docker runtime)
#   - llama.cpp (built from source, Metal backend)
#   - LiteLLM bridge (Docker)
#   - claw-code (Docker)
#   - Qwen2.5-7B-Instruct Q5_K_M GGUF (~5 GB)
#
# Single-machine install: everything runs on the same 16 GB Apple Silicon Mac.
# Idempotent — safe to re-run.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GGUF_DIR="$HOME/.ollama/gguf"
GGUF_FILE="Qwen2.5-7B-Instruct-Q5_K_M.gguf"
GGUF_URL="https://huggingface.co/bartowski/Qwen2.5-7B-Instruct-GGUF/resolve/main/$GGUF_FILE"
LLAMA_SRC="$HOME/src/llama.cpp"
LOCAL_BIN="$HOME/.local/bin"

say()  { printf '\n=== %s ===\n' "$*"; }
have() { command -v "$1" >/dev/null 2>&1; }
die()  { echo "error: $*" >&2; exit 1; }

# 0. Sanity checks
[[ "$(uname -s)" == "Darwin" ]] || die "macOS only"
[[ "$(uname -m)" == "arm64"  ]] || die "Apple Silicon only"
xcode-select -p >/dev/null 2>&1 || die "run: xcode-select --install (then re-run this)"
have git   || die "git not found (Xcode CLT should provide it)"
have cmake || die "cmake not found — download from https://cmake.org/download/, extract, symlink the cmake binary into ~/.local/bin/"

# 1. OrbStack
if [ ! -d /Applications/OrbStack.app ] && ! have orb; then
    say "installing OrbStack"
    curl -fsSL https://orbstack.dev/install.sh | bash
fi
have docker || die "docker not on PATH — open OrbStack.app once to finish setup, then re-run"

# 2. llama.cpp
say "building llama.cpp (Metal)"
mkdir -p "$LLAMA_SRC" "$LOCAL_BIN"
[ -d "$LLAMA_SRC/.git" ] || git clone --depth=1 https://github.com/ggml-org/llama.cpp "$LLAMA_SRC"
(
    cd "$LLAMA_SRC"
    cmake -B build -DGGML_METAL=ON -DLLAMA_CURL=OFF -DLLAMA_BUILD_SERVER=ON
    cmake --build build --config Release -j --target llama-server
)
ln -sf "$LLAMA_SRC/build/bin/llama-server" "$LOCAL_BIN/llama-server"

# 3. GGUF (~5 GB; -C - resumes if interrupted)
say "downloading 16 GB-tier model: $GGUF_FILE"
mkdir -p "$GGUF_DIR"
curl -L -C - -o "$GGUF_DIR/$GGUF_FILE" "$GGUF_URL"

# 4. .env files (only write if missing)
say "writing .env files"
if [ ! -f "$REPO/host/litellm/.env" ]; then
    cp "$REPO/host/litellm/.env.example" "$REPO/host/litellm/.env"
    KEY="sk-ant-claw-$(openssl rand -hex 12)"
    sed -i '' "s|^LITELLM_MASTER_KEY=.*|LITELLM_MASTER_KEY=$KEY|" "$REPO/host/litellm/.env"
fi
HOST_KEY=$(grep ^LITELLM_MASTER_KEY= "$REPO/host/litellm/.env" | cut -d= -f2-)

if [ ! -f "$REPO/client/claw-code/.env" ]; then
    cp "$REPO/client/claw-code/.env.example" "$REPO/client/claw-code/.env"
    sed -i '' \
        -e "s|^LITELLM_MASTER_KEY=.*|LITELLM_MASTER_KEY=$HOST_KEY|" \
        -e "s|^BRIDGE_HOST=.*|BRIDGE_HOST=host.docker.internal|" \
        "$REPO/client/claw-code/.env"
fi
mkdir -p "$REPO/client/claw-code/workspace"

# 5. llama-server LaunchAgent (renders the plist for tier 16, bootstraps it)
say "installing llama-server LaunchAgent (tier 16)"
"$REPO/host/llama-server/scripts/install" --size 16

# 6. Bring up Docker stacks
say "starting LiteLLM bridge"
( cd "$REPO/host/litellm" && docker compose up -d )

say "building + starting claw-code (first build is 5-10 min: cargo --release)"
( cd "$REPO/client/claw-code" && docker compose up -d --build )

# 7. Done
cat <<EOM

==================================================================
  install complete.

  smoke test:
    docker compose -f client/claw-code/docker-compose.yml exec claw claw doctor

  REPL (always pass --model anthropic/claw on this 16 GB stack):
    docker compose -f client/claw-code/docker-compose.yml exec -it claw \\
        claw --model anthropic/claw

  workspace files land at: $REPO/client/claw-code/workspace/
==================================================================
EOM
