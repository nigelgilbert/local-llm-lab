# LLM Lab client config. Copy to ~/.config/home-llm-lab/config.env and edit.

# Hostname or IP of the LLM Lab host on your LAN.
# Falls back to home-llm-lab.local (mDNS). Use the DHCP-reserved IP if mDNS fails.
HOME_LLM_LAB_HOST=home-llm-lab.local

# SSH user on the host. Default: your local username.
HOME_LLM_LAB_USER=nigel

# OWUI base URL the browser opens to.
# Same hostname as HOME_LLM_LAB_HOST in MVP. Phase 2 swaps to *.ts.net (Tailscale).
HOME_LLM_LAB_OPENUI_BASE=http://home-llm-lab.local

# Path to home-llm-lab-hostctl on the host. Resolved via host $PATH, so a symlink
# in /usr/local/bin/ is enough.
HOME_LLM_LAB_HOSTCTL=home-llm-lab-hostctl
