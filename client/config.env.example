# LLM Lab client config. Copy to ~/.config/mac-llm-lab/config.env and edit.

# Hostname or IP of the LLM Lab host on your LAN.
# Falls back to mac-llm-lab.local (mDNS). Use the DHCP-reserved IP if mDNS fails.
MAC_LLM_LAB_HOST=mac-llm-lab.local

# SSH user on the host. Default: your local username.
MAC_LLM_LAB_USER=nigel

# OWUI base URL the browser opens to.
# Same hostname as MAC_LLM_LAB_HOST in MVP. Phase 2 swaps to *.ts.net (Tailscale).
MAC_LLM_LAB_OPENUI_BASE=http://mac-llm-lab.local

# Path to mac-llm-lab-hostctl on the host. Resolved via host $PATH, so a symlink
# in /usr/local/bin/ is enough.
MAC_LLM_LAB_HOSTCTL=mac-llm-lab-hostctl
