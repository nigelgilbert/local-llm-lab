# Cyberia client config. Copy to ~/.config/cyberia/config.env and edit.

# Hostname or IP of the Cyberia host on your LAN.
# Falls back to cyberia.local (mDNS). Use the DHCP-reserved IP if mDNS fails.
CYBERIA_HOST=cyberia.local

# SSH user on the host. Default: your local username.
CYBERIA_USER=nigel

# OWUI base URL the browser opens to.
# Same hostname as CYBERIA_HOST in MVP. Phase 2 swaps to *.ts.net (Tailscale).
CYBERIA_OPENUI_BASE=http://cyberia.local

# Path to cyberia-hostctl on the host. Resolved via host $PATH, so a symlink
# in /usr/local/bin/ is enough.
CYBERIA_HOSTCTL=cyberia-hostctl
