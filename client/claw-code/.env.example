# claw-code client config. Copy to .env and edit. .env is gitignored.

# Host directory bind-mounted to /workspace inside the claw container.
# Default is a sibling `workspace/` dir; set to any absolute path you prefer.
WORKSPACE=./workspace

# Where the LiteLLM bridge lives, as seen from inside this container.
# - LAN client (your laptop):    cyberia.local  (or DHCP-reserved IP if mDNS flakes)
# - Same machine as the bridge:  host.docker.internal
BRIDGE_HOST=cyberia.local
BRIDGE_PORT=4000

# Must match LITELLM_MASTER_KEY from host/litellm/.env on the bridge box.
LITELLM_MASTER_KEY=sk-ant-cyberia-bridge-changeme

# Git ref to build claw from. Pin to a tag/commit for reproducibility once
# upstream stabilises; `main` is fine while iterating.
CLAW_REF=main
