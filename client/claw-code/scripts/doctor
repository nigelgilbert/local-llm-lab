#!/usr/bin/env bash
# Diagnostic script for the claw-code Docker setup.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
COMPOSE_DIR="$(dirname "$SCRIPT_DIR")"
ENV_FILE="$COMPOSE_DIR/.env"

ok()   { printf "  \033[32m✓\033[0m  %s\n" "$*"; }
warn() { printf "  \033[33m!\033[0m  %s\n" "$*"; }
fail() { printf "  \033[31m✗\033[0m  %s\n" "$*"; }
hdr()  { printf "\n\033[1m%s\033[0m\n" "$*"; }

hdr "=== claw-code doctor ==="

# --- .env ---
hdr "Config (.env)"
if [ -f "$ENV_FILE" ]; then
  ok ".env found"
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  echo "    BRIDGE_HOST=$BRIDGE_HOST"
  echo "    BRIDGE_PORT=$BRIDGE_PORT"
  echo "    WORKSPACE=$WORKSPACE"
  key_preview="${LITELLM_MASTER_KEY:0:12}..."
  echo "    LITELLM_MASTER_KEY=$key_preview"
else
  fail ".env not found (copy .env.example)"
fi

# --- workspace ---
hdr "Workspace"
if [ -d "${WORKSPACE:-}" ]; then
  ok "WORKSPACE exists: $WORKSPACE"
else
  warn "WORKSPACE missing or not set: ${WORKSPACE:-<unset>}"
fi

# --- docker ---
hdr "Docker / OrbStack"
if docker info &>/dev/null; then
  ok "Docker daemon reachable"
else
  fail "Docker daemon not reachable"
fi

# --- container state ---
hdr "Container (claw-code)"
STATE=$(docker inspect --format '{{.State.Status}}' claw-code 2>/dev/null || echo "not found")
case "$STATE" in
  running) ok "Container running" ;;
  exited)  warn "Container exited" ;;
  "not found") fail "Container not found (run: docker compose up -d)" ;;
  *)       warn "Container state: $STATE" ;;
esac

if [ "$STATE" = "running" ]; then
  # processes inside container
  hdr "Processes inside container"
  PROCS=$(docker exec claw-code ps aux 2>/dev/null | grep -E "npm|npx|node|create-next" | grep -v grep || true)
  if [ -n "$PROCS" ]; then
    ok "Active node/npm processes:"
    echo "$PROCS" | sed 's/^/    /'
  else
    warn "No npm/node processes running"
  fi

  # resource usage
  hdr "Container resource usage"
  docker stats claw-code --no-stream --format \
    "    CPU: {{.CPUPerc}}  MEM: {{.MemUsage}}  NET I/O: {{.NetIO}}  BLOCK I/O: {{.BlockIO}}"

  # node / npm versions
  hdr "Runtime versions (inside container)"
  NODE_VER=$(docker exec claw-code node --version 2>/dev/null || echo "not installed")
  NPM_VER=$(docker exec claw-code npm --version 2>/dev/null || echo "not installed")
  [ "$NODE_VER" != "not installed" ] && ok "node $NODE_VER" || fail "node not installed"
  [ "$NPM_VER"  != "not installed" ] && ok "npm  $NPM_VER"  || fail "npm not installed"
fi

# --- related containers ---
hdr "Related containers"
docker ps --format "    {{.Names}}\t{{.Status}}\t{{.Image}}" \
  | grep -E "litellm|ollama|openwebui|home-llm-lab" \
  | while IFS=$'\t' read -r name status image; do
      if [[ "$status" == Up* ]]; then ok "$name  ($status)  $image"
      else fail "$name  ($status)  $image"
      fi
    done || warn "No related containers found"

# --- bridge reachability ---
# Check from host using localhost (host.docker.internal is container-only).
hdr "LiteLLM bridge"
BRIDGE_URL="http://${BRIDGE_HOST:-home-llm-lab.local}:${BRIDGE_PORT:-4000}"
HOST_BRIDGE_URL="http://localhost:${BRIDGE_PORT:-4000}"
if curl -sf --max-time 3 "$HOST_BRIDGE_URL/health/liveliness" &>/dev/null; then
  ok "Bridge reachable at $HOST_BRIDGE_URL (container address: $BRIDGE_URL)"
else
  fail "Bridge not reachable at $HOST_BRIDGE_URL"
fi

# --- model ---
hdr "Model (via bridge)"
MODEL_RESP=$(curl -sf --max-time 5 \
  -H "Authorization: Bearer ${LITELLM_MASTER_KEY:-}" \
  "$HOST_BRIDGE_URL/v1/models" 2>/dev/null || echo "")
if [ -n "$MODEL_RESP" ]; then
  ok "Models endpoint responded"
  echo "$MODEL_RESP" | python3 -c \
    "import sys,json; [print('    -', m['id']) for m in json.load(sys.stdin).get('data',[])]" \
    2>/dev/null || true
else
  fail "Could not reach models endpoint (check LITELLM_MASTER_KEY and bridge)"
fi

printf "\n\033[1m=== done ===\033[0m\n\n"
