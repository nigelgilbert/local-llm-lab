#!/usr/bin/env sh
# cyberia — thin client wrapper for the Cyberia LAN AI lab.
# SSHes the host for control actions, opens the browser for chat.
#
# Subcommands:
#   chat [-p profile] [-q "..."]    open browser to OWUI deep-link
#   status                          host health summary (via SSH)
#   warm -p <profile>               preload model on host (via SSH)

set -eu

CONFIG="${CYBERIA_CONFIG:-$HOME/.config/cyberia/config.env}"

# Defaults — overridden by config.env if present.
CYBERIA_HOST=cyberia.local
CYBERIA_USER="$USER"
CYBERIA_OPENUI_BASE=http://cyberia.local
CYBERIA_HOSTCTL=cyberia-hostctl

[ -f "$CONFIG" ] && . "$CONFIG"

err() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }

ssh_host() {
  ssh -o BatchMode=yes -o ConnectTimeout=5 \
    "${CYBERIA_USER}@${CYBERIA_HOST}" "$@"
}

open_url() {
  url=$1
  case "$(uname -s)" in
    Darwin) open "$url" ;;
    Linux)  command -v xdg-open >/dev/null 2>&1 && xdg-open "$url" || printf '%s\n' "$url" ;;
    *)      printf '%s\n' "$url" ;;
  esac
}

url_encode() {
  python3 -c 'import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1]))' "$1"
}

profile_to_model() {
  case "$1" in
    general|fast|reasoning|digest|analyze) printf '%s' "$1" ;;
    *) err "unknown profile: $1 (valid: general, fast, reasoning, digest, analyze)" ;;
  esac
}

cmd_chat() {
  profile=
  query=
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -p|--profile) profile="${2:-}"; shift 2 ;;
      -q|--query)   query="${2:-}";   shift 2 ;;
      *) err "unknown arg: $1" ;;
    esac
  done

  url="$CYBERIA_OPENUI_BASE"
  if [ -n "$profile" ]; then
    model=$(profile_to_model "$profile")
    url="$url/?model=$model"
    [ -n "$query" ] && url="$url&q=$(url_encode "$query")"
    # Fire-and-forget warm so the model is hot by the time the browser arrives.
    ssh_host "$CYBERIA_HOSTCTL warm $profile" >/dev/null 2>&1 || true
  fi

  open_url "$url"
}

cmd_status() {
  ssh_host "$CYBERIA_HOSTCTL status"
}

cmd_warm() {
  profile=
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -p|--profile) profile="${2:-}"; shift 2 ;;
      *) err "unknown arg: $1" ;;
    esac
  done
  [ -n "$profile" ] || err "usage: cyberia warm -p <profile>"
  ssh_host "$CYBERIA_HOSTCTL warm $profile"
}

usage() {
  cat <<EOF
cyberia — client wrapper for Cyberia LAN AI lab

Usage:
  cyberia chat                              open Open WebUI bare
  cyberia chat -p <profile>                 open with model preselected
  cyberia chat -p <profile> -q "<query>"    preselect + prefill query
  cyberia status                            host health summary
  cyberia warm -p <profile>                 preload model on host

Profiles: general, fast, reasoning, digest, analyze

Config: $CONFIG (see client/config.env.example)
EOF
}

case "${1:-}" in
  chat)              shift; cmd_chat "$@" ;;
  status)            shift; cmd_status "$@" ;;
  warm)              shift; cmd_warm "$@" ;;
  -h|--help|help|"") usage ;;
  *) err "unknown subcommand: $1 (try --help)" ;;
esac
