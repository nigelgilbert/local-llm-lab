# LiteLLM bridge config. Copy to .env and edit. .env is gitignored.

# Ollama backend reachable from inside the LiteLLM container. `host.docker.internal`
# resolves to the Mac host on Docker Desktop / OrbStack.
OLLAMA_HOST=host.docker.internal
OLLAMA_PORT=11434

# Shared secret. Clients (claw-code, etc.) send this as ANTHROPIC_API_KEY.
# Anthropic-style prefix keeps strict CLI key-format validators happy.
# Rotate by editing here + every client's .env, then `docker compose up -d --force-recreate`.
LITELLM_MASTER_KEY=sk-ant-cyberia-bridge-changeme
