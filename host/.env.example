# Cyberia / Open WebUI configuration.
# Copy to host/.env and edit. host/.env is git-ignored — secrets like
# WEBUI_SECRET_KEY belong here.

# Ollama backend reachable from inside the OWUI container.
# `host.docker.internal` resolves to the Mac host on Docker Desktop / OrbStack.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Auth on — required for multi-user attribution.
WEBUI_AUTH=true

# Open signup, no admin approval, new users auto-activate as `user`.
# Default DEFAULT_USER_ROLE is `pending` (admin-approval queue). Override
# to `user` per spec §7.3.
ENABLE_SIGNUP=true
DEFAULT_USER_ROLE=user

# Branding shown in the title bar / browser tab.
WEBUI_NAME=Cyberia
WEBUI_URL=http://cyberia.local

# Auto-assign new signups to a group. Leave blank for the first boot (no
# groups exist yet); fill in after creating the Guests group, then
# `docker compose up -d --force-recreate`.
DEFAULT_GROUP_ID=
