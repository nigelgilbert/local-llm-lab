# claw.gbnf — grammar for qwen3-coder tool-use against the LiteLLM bridge.
#
# What this enforces:
#   1. Optional preamble text (model may "think out loud" before calling).
#   2. If a tool is called, it MUST be wrapped in <tool_call>...</tool_call>.
#   3. Inside the wrapping, the JSON MUST have "name" and "arguments" fields
#      with valid JSON values; the rest is permissive.
#   4. After the closing tag, optional trailing text is allowed.
#
# What this does NOT enforce (intentionally):
#   - Specific tool names or argument schemas. claw advertises 50+ tools and
#     the set drifts with claw versions; pinning the schema here would couple
#     us to the client. The model is already reliable on tool-name and
#     arg-shape correctness — the bug is the *wrapping*, which is what we fix.
#   - Whether the model calls a tool at all. Grammar can't make the model
#     *want* to act; it can only make sure the format is correct *if* it does.
#
# Notes on the GBNF dialect (llama.cpp):
#   - No lookahead. The "char that doesn't start <tool_call>" trick uses
#     explicit alternation: either not-a-`<`, or `<` followed by not-a-`t`.
#     This is approximate (allows `<test>` etc. in prose, which is fine).
#   - String escapes inside JSON-string accept the standard JSON set.
#
# Validate:
#   ~/.local/bin/llama-server --grammar-file claw.gbnf --help >/dev/null
#   (a malformed grammar errors out at startup.)

root             ::= prelude? response

prelude          ::= prose-char+
response         ::= tool-call | trailing-text
trailing-text    ::= prose-char+

tool-call        ::= "<tool_call>" newline tool-payload newline "</tool_call>" tail?
tail             ::= prose-char+

# Wrapped payload MUST be { "name": "...", "arguments": {...} }.
# Field order is fixed to match qwen3-coder's training distribution.
# Single line: llama.cpp's GBNF parser doesn't accept rules split across newlines.
tool-payload     ::= "{" ws "\"name\"" ws ":" ws json-string ws "," ws "\"arguments\"" ws ":" ws json-object ws "}"

# A character that does NOT begin the literal "<tool_call>".
# Approximate: anything except `<`, or `<` followed by a non-`t`.
prose-char       ::= [^<] | "<" [^t]
newline          ::= "\n"

# Permissive JSON — accepts any well-formed JSON value, object, or array.
json-any         ::= json-string | json-number | json-bool | json-null | json-object | json-array
json-object      ::= "{" ws ( json-pair ( ws "," ws json-pair )* )? ws "}"
json-pair        ::= json-string ws ":" ws json-any
json-array       ::= "[" ws ( json-any ( ws "," ws json-any )* )? ws "]"
json-string      ::= "\"" json-char* "\""
json-char        ::= [^"\\] | "\\" json-escape
json-escape      ::= ["\\/bfnrt] | "u" hex hex hex hex
hex              ::= [0-9a-fA-F]
json-number      ::= "-"? ( "0" | [1-9] [0-9]* ) ( "." [0-9]+ )? ( [eE] [+-]? [0-9]+ )?
json-bool        ::= "true" | "false"
json-null        ::= "null"
ws               ::= [ \t\n\r]*
