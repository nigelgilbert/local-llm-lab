#!/usr/bin/env bash
# install — render the llama-server plist for the given memory tier and bootstrap it.
# Usage: ./scripts/install [--size 16|32|64]
# Auto-detects from sysctl hw.memsize when --size is omitted.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$SCRIPT_DIR/.."
PLIST_TEMPLATE="$ROOT/launchd/com.mac-llm-lab.llama-server.plist"
PLIST_DEST="$HOME/Library/LaunchAgents/com.mac-llm-lab.llama-server.plist"
LABEL="com.mac-llm-lab.llama-server"

# shellcheck source=../models.conf
source "$ROOT/models.conf"

detect_tier() {
    local mem_bytes mem_gb
    mem_bytes=$(sysctl -n hw.memsize)
    mem_gb=$(( mem_bytes / 1024 / 1024 / 1024 ))
    if   (( mem_gb >= 48 )); then echo 64
    elif (( mem_gb >= 24 )); then echo 32
    else                          echo 16
    fi
}

TIER="${LLAMA_TIER:-}"
while [[ $# -gt 0 ]]; do
    case "$1" in
        --size) TIER="$2"; shift 2 ;;
        *)      echo "unknown arg: $1" >&2; exit 1 ;;
    esac
done
[[ -z "$TIER" ]] && TIER=$(detect_tier)

case "$TIER" in
    16|32|64) ;;
    *) echo "invalid tier: $TIER (expected 16, 32, or 64)" >&2; exit 1 ;;
esac

eval "GGUF=\"\$TIER_${TIER}_GGUF\""
eval "CTX=\"\$TIER_${TIER}_CTX\""
eval "BATCH=\"\$TIER_${TIER}_BATCH\""
eval "TEMP=\"\$TIER_${TIER}_TEMP\""
eval "TOP_P=\"\$TIER_${TIER}_TOP_P\""
eval "TOP_K=\"\$TIER_${TIER}_TOP_K\""
eval "REPEAT_PENALTY=\"\$TIER_${TIER}_REPEAT_PENALTY\""
eval "PRESENCE_PENALTY=\"\$TIER_${TIER}_PRESENCE_PENALTY\""

if [[ -z "$GGUF" ]]; then
    echo "tier ${TIER}GB: GGUF not configured — set TIER_${TIER}_GGUF in models.conf." >&2
    exit 1
fi
for v in TEMP TOP_P TOP_K REPEAT_PENALTY PRESENCE_PENALTY; do
    if [[ -z "${!v}" ]]; then
        echo "tier ${TIER}GB: TIER_${TIER}_${v} not set in models.conf." >&2
        exit 1
    fi
done
if [[ ! -f "$GGUF" ]]; then
    echo "tier ${TIER}GB: GGUF not found: $GGUF" >&2
    echo "See models.conf for the curl command for this tier." >&2
    exit 1
fi

BINARY="$HOME/.local/bin/llama-server"
GRAMMAR="$(realpath "$ROOT/grammars/claw.gbnf")"

echo "installing llama-server (tier ${TIER}GB): $(basename "$GGUF")"

launchctl bootout "gui/$(id -u)/$LABEL" 2>/dev/null || true

mkdir -p "$HOME/Library/LaunchAgents"
sed \
    -e "s|__BINARY__|$BINARY|g" \
    -e "s|__GGUF_PATH__|$GGUF|g" \
    -e "s|__CTX_SIZE__|$CTX|g" \
    -e "s|__BATCH_SIZE__|$BATCH|g" \
    -e "s|__GRAMMAR_PATH__|$GRAMMAR|g" \
    -e "s|__TEMP__|$TEMP|g" \
    -e "s|__TOP_P__|$TOP_P|g" \
    -e "s|__TOP_K__|$TOP_K|g" \
    -e "s|__REPEAT_PENALTY__|$REPEAT_PENALTY|g" \
    -e "s|__PRESENCE_PENALTY__|$PRESENCE_PENALTY|g" \
    "$PLIST_TEMPLATE" > "$PLIST_DEST"

launchctl bootstrap "gui/$(id -u)" "$PLIST_DEST"
echo "started: $LABEL on :11435 (~10–20s for model load)"
