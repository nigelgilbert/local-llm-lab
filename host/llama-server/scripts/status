#!/usr/bin/env sh
# status — show LaunchAgent state + reachability of the claw endpoint.
set -eu
LABEL="com.cyberia.llama-server"
API="${LLAMA_SERVER_API:-http://127.0.0.1:11435}"

if launchctl print "gui/$(id -u)/$LABEL" >/dev/null 2>&1; then
  launchctl print "gui/$(id -u)/$LABEL" | awk '/^\tstate =|^\tpid =/ {print}'
else
  echo "not loaded"
fi

if curl -fsS "$API/health" >/dev/null 2>&1; then
  echo "reachable: $API"
else
  echo "unreachable: $API"
fi
