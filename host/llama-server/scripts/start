#!/usr/bin/env sh
# start — bootstrap the llama-server LaunchAgent (claw backend on :11435).
set -eu
PLIST="$HOME/Library/LaunchAgents/com.cyberia.llama-server.plist"
[ -f "$PLIST" ] || { echo "missing: $PLIST (install per host/llama-server/README.md)" >&2; exit 1; }
launchctl bootstrap "gui/$(id -u)" "$PLIST"
echo "started: com.cyberia.llama-server (model load takes ~10–20s)"
