#!/usr/bin/env bash
# install-qwen35 — render the qwen3.5 sweep plist and bootstrap it.
#
# Sprint 1.19 Exploratory Mini Sweep 2 only. DELETE after sweep coalesces.
#
# Usage:
#   GGUF=...  CTX=32768  REPEAT_PEN=1.1  ./install-qwen35
#   GGUF=...  CTX=65536  REPEAT_PEN=1.0  TEMP=0.7  MIN_P=0.0  ./install-qwen35
#
# Env:
#   GGUF        absolute path to a Qwen3.5-9B GGUF
#   CTX         context size (32768 or 65536)
#   REPEAT_PEN  repeat-penalty (1.1 for c6 carryover; 1.0 to disable)
#   TEMP        (optional, default 0.6) — c6 sampler temp
#   MIN_P       (optional, default 0.05) — llama.cpp default; flip to 0.0
#               for Qwen3.5 vendor-rec (Sweep 4 cell α)
#   BATCH       (optional, default 4096)
#
# Restores the production plist when scripts/install --size 32 is re-run.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$SCRIPT_DIR/.."
PLIST_TEMPLATE="$ROOT/launchd/com.mac-llm-lab.llama-server-qwen35.plist"
PLIST_DEST="$HOME/Library/LaunchAgents/com.mac-llm-lab.llama-server.plist"
LABEL="com.mac-llm-lab.llama-server"

: "${GGUF:?GGUF env var required}"
: "${CTX:?CTX env var required}"
: "${REPEAT_PEN:?REPEAT_PEN env var required}"
BATCH="${BATCH:-4096}"
TEMP="${TEMP:-0.6}"
MIN_P="${MIN_P:-0.05}"

[[ -f "$GGUF" ]] || { echo "GGUF not found: $GGUF" >&2; exit 1; }

BINARY="$HOME/.local/bin/llama-server"
GRAMMAR="$(realpath "$ROOT/grammars/claw.gbnf")"

echo "installing llama-server (qwen3.5 sweep): $(basename "$GGUF") ctx=$CTX temp=$TEMP min_p=$MIN_P rep=$REPEAT_PEN"

launchctl bootout "gui/$(id -u)/$LABEL" 2>/dev/null || true

mkdir -p "$HOME/Library/LaunchAgents"
sed \
    -e "s|__BINARY__|$BINARY|g" \
    -e "s|__GGUF_PATH__|$GGUF|g" \
    -e "s|__CTX_SIZE__|$CTX|g" \
    -e "s|__BATCH_SIZE__|$BATCH|g" \
    -e "s|__GRAMMAR_PATH__|$GRAMMAR|g" \
    -e "s|__TEMP__|$TEMP|g" \
    -e "s|__MIN_P__|$MIN_P|g" \
    -e "s|__REPEAT_PENALTY__|$REPEAT_PEN|g" \
    "$PLIST_TEMPLATE" > "$PLIST_DEST"

launchctl bootstrap "gui/$(id -u)" "$PLIST_DEST"
echo "started: $LABEL on :11435 (~10–30s for model load)"
