# digest — long-context extract / summarize profile, no thinking.
# Backing model: Qwen3-30B-A3B-Instruct-2507 UD-Q4_K_XL (HuggingFace GGUF, unsloth Dynamic 2.0).
# Selection rationale: ../../../profiles.md.
#
# Sibling of `analyze` (Thinking-2507, with <think> blocks). Use `digest`
# for direct extraction / summary over a corpus; use `analyze` when you
# want it to reason across the material before answering.
#
# `FROM` is rig-specific — Ollama Modelfiles do NOT expand ~ or $HOME.
# Drop the GGUF in ~/.ollama/gguf/ first; see ../README.md §3c.
# Forking? Edit the username in the path below to match your rig.

FROM /Users/nigel/.ollama/gguf/Qwen3-30B-A3B-Instruct-2507-UD-Q4_K_XL.gguf

PARAMETER num_ctx 262144

# Sampling: Qwen3-30B-A3B-Instruct-2507 vendor-recommended defaults.
# https://huggingface.co/Qwen/Qwen3-30B-A3B-Instruct-2507
PARAMETER temperature 0.7
PARAMETER top_p 0.8
PARAMETER top_k 20
PARAMETER min_p 0
PARAMETER num_predict 16384
