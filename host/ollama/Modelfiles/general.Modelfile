# general — daily driver profile.
# Backing model: Qwen3.6-27B Q8_0 (Ollama library).
# Selection rationale: ../../../profiles.md.

FROM qwen3.6:27b-q8_0

# 131072 satisfies vendor's 128K minimum for preserving thinking-mode quality.
PARAMETER num_ctx 131072

# Sampling: Qwen3.6-27B vendor-recommended "thinking — general" profile.
# https://huggingface.co/Qwen/Qwen3.6-27B
PARAMETER temperature 1.0
PARAMETER top_p 0.95
PARAMETER top_k 20
PARAMETER min_p 0
PARAMETER presence_penalty 0

# Profile deviation: vendor specifies repeat_penalty 1.0; bumped to 1.2 as a
# light anti-repetition guard. Lower if it suppresses legitimate repetition.
PARAMETER repeat_penalty 1.2
